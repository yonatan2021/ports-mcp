{
  "name": "ports-mcp",
  "version": "1.0.0",
  "author": "Yonatan",
  "description": "Local-only macOS port manager with a guarded MCP stdio server and optional web UI.",
  "main": "desktop/main.js",
  "bin": {
    "ports-mcp": "src/mcp-server.js"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "HOST=127.0.0.1 PORT=9999 node server.js",
    "mcp": "node src/mcp-server.js",
    "test": "node --test",
    "desktop": "electron .",
    "package:mac": "electron-builder --mac"
  },
  "keywords": [
    "port-manager",
    "macos",
    "process-manager",
    "mcp",
    "sysadmin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonatan2021/ports-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/yonatan2021/ports-mcp/issues"
  },
  "homepage": "https://github.com/yonatan2021/ports-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.yonatan2021.portsmcp",
    "productName": "Port Manager",
    "icon": "build/icon.icns",
    "files": [
      "desktop/**/*",
      "public/**/*",
      "src/**/*",
      "server.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
